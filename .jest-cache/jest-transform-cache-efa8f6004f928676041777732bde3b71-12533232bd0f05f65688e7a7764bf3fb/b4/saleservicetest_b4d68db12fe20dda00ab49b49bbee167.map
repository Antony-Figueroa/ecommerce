import { jest } from '@jest/globals'
import { SaleService } from '../sale.service.js'
import { NotFoundError } from '../../../shared/errors/app.errors.js'

describe('SaleService', () => {
  let saleService: SaleService
  let mockSaleRepo: any
  let mockProductRepo: any
  let mockLogRepo: any
  let mockBcvRepo: any
  let mockBatchRepo: any
  let mockNotificationRepo: any
  let mockSettingsRepo: any
  let mockNotificationService: any

  beforeEach(() => {
    mockSaleRepo = {
      create: jest.fn(),
      findById: jest.fn(),
      update: jest.fn(),
      findAll: jest.fn(),
      count: jest.fn(),
      findBySaleNumber: jest.fn(),
      findDuplicate: jest.fn(),
      createAuditLog: jest.fn(),
    }
    mockProductRepo = {
      findById: jest.fn(),
      update: jest.fn(),
    }
    mockLogRepo = {
      create: jest.fn(),
    }
    mockBcvRepo = {
      getCurrentRate: jest.fn().mockResolvedValue(36),
    }
    mockBatchRepo = {
      findMany: jest.fn(),
      update: jest.fn(),
    }
    mockNotificationRepo = {
      create: jest.fn(),
    }
    mockSettingsRepo = {
      findByKey: jest.fn(),
    }
    mockNotificationService = {
      notifySaleStatusChange: jest.fn(),
      notifyLowStock: jest.fn(),
    }

    saleService = new SaleService(
      mockSaleRepo,
      mockProductRepo,
      mockLogRepo,
      mockBcvRepo,
      mockBatchRepo,
      mockNotificationRepo,
      mockSettingsRepo,
      mockNotificationService
    )
  })

  describe('createSale', () => {
    const mockProduct = {
      id: 'prod-1',
      name: 'Product 1',
      purchasePrice: 10,
      shippingCost: 2,
      stock: 20,
    }

    const saleData = {
      userId: 'user-1',
      items: [
        {
          productId: 'prod-1',
          name: 'Product 1',
          quantity: 2,
          unitPrice: 20,
        },
      ],
      bcvRate: 36,
    }

    it('should create a sale successfully', async () => {
      mockProductRepo.findById.mockResolvedValue(mockProduct)
      mockSaleRepo.findBySaleNumber.mockResolvedValue(null)
      mockSaleRepo.create.mockResolvedValue({ id: 'sale-1', saleNumber: 'VTA-001' })
      mockBatchRepo.findMany.mockResolvedValue([
        { id: 'batch-1', stock: 10, expirationDate: new Date() },
        { id: 'batch-2', stock: 20, expirationDate: new Date() },
      ])

      const result = await saleService.createSale(saleData)

      expect(mockProductRepo.findById).toHaveBeenCalledWith('prod-1')
      expect(mockSaleRepo.create).toHaveBeenCalled()
      expect(mockProductRepo.update).toHaveBeenCalledWith('prod-1', expect.objectContaining({
        stock: 18,
        inStock: true,
      }))
      expect(mockLogRepo.create).toHaveBeenCalled()
      expect(result).toBeDefined()
    })

    it('should throw NotFoundError if product does not exist', async () => {
      mockProductRepo.findById.mockResolvedValue(null)

      await expect(saleService.createSale(saleData)).rejects.toThrow(NotFoundError)
    })

    it('should calculate totals correctly', async () => {
      mockProductRepo.findById.mockResolvedValue(mockProduct)
      mockSaleRepo.findBySaleNumber.mockResolvedValue(null)
      mockSaleRepo.create.mockImplementation((data: any) => Promise.resolve({ ...data, id: 'sale-1' }))
      mockBatchRepo.findMany.mockResolvedValue([])

      await saleService.createSale(saleData)

      const createCall = mockSaleRepo.create.mock.calls[0][0]
      expect(createCall.subtotalUSD).toBe(40) // 2 * 20
      expect(createCall.totalUSD).toBe(40)
      expect(createCall.totalBS).toBe(40 * 36)
      expect(createCall.profitUSD).toBe(16) // (20 - (10+2)) * 2 = 8 * 2 = 16
    })
  })

  describe('getSaleById', () => {
    it('should return sale if found', async () => {
      const mockSale = { id: 'sale-1', saleNumber: 'VTA-001' }
      mockSaleRepo.findById.mockResolvedValue(mockSale)

      const result = await saleService.getSaleById('sale-1')

      expect(result).toEqual(mockSale)
    })

    it('should throw NotFoundError if not found', async () => {
      mockSaleRepo.findById.mockResolvedValue(null)

      await expect(saleService.getSaleById('999')).rejects.toThrow(NotFoundError)
    })
  })

  describe('cancelSale', () => {
    it('should cancel sale and restore stock', async () => {
      const mockSale = {
        id: 'sale-1',
        status: 'PENDING',
        items: [
          { productId: 'prod-1', quantity: 2, batchId: 'batch-1' }
        ]
      }
      mockSaleRepo.findById.mockResolvedValue(mockSale)
      mockProductRepo.findById.mockResolvedValue({ id: 'prod-1', stock: 10 })
      mockBatchRepo.findMany.mockResolvedValue([{ id: 'batch-1', stock: 5 }])

      await saleService.cancelSale('sale-1', 'admin-1', 'Cancelado por el cliente')

      expect(mockSaleRepo.update).toHaveBeenCalledWith('sale-1', { status: 'CANCELLED' })
      expect(mockProductRepo.update).toHaveBeenCalledWith('prod-1', { stock: 12, inStock: true })
      expect(mockBatchRepo.update).toHaveBeenCalledWith('batch-1', { stock: 7 })
    })
  })

  describe('updateSaleItemStatus', () => {
    it('should update item status and product stock if rejected', async () => {
      const mockSale = {
        id: 'sale-1',
        items: [
          { id: 'item-1', productId: 'prod-1', quantity: 2, status: 'PENDING' }
        ]
      }
      mockSaleRepo.findById.mockResolvedValue(mockSale)
      mockProductRepo.findById.mockResolvedValue({ id: 'prod-1', stock: 10 })

      await saleService.updateSaleItemStatus('sale-1', 'item-1', 'REJECTED', 'admin-1')

      expect(mockProductRepo.update).toHaveBeenCalledWith('prod-1', { stock: 12, inStock: true })
      expect(mockSaleRepo.update).toHaveBeenCalled()
    })
  })

  describe('confirmPayment', () => {
    it('should complete sale and notify client', async () => {
      const mockSale = { id: 'sale-1', status: 'PENDING', saleNumber: 'V-001', customerName: 'John', customerPhone: '12345', userId: 'user-1' }
      mockSaleRepo.findById.mockResolvedValue(mockSale)
      mockSaleRepo.update.mockResolvedValue({ ...mockSale, status: 'COMPLETED', isPaid: true })

      const result = await saleService.confirmPayment('sale-1', 100, 'admin-1')

      expect(result.status).toBe('COMPLETED')
      expect(mockSaleRepo.createAuditLog).toHaveBeenCalledWith(expect.objectContaining({ action: 'PAYMENT_CONFIRMED' }))
      expect(mockNotificationRepo.create).toHaveBeenCalledWith(expect.objectContaining({ type: 'SALE_STATUS' }))
    })
  })

  describe('respondToProposal', () => {
    it('should accept proposal and update status to PROCESSING', async () => {
      const mockSale = { 
        id: 'sale-1', 
        status: 'PROPOSED', 
        userId: 'user-1', 
        customerName: 'John',
        items: [{ name: 'Item 1', quantity: 1, status: 'ACCEPTED' }]
      }
      mockSaleRepo.findById.mockResolvedValue(mockSale)
      mockSaleRepo.update.mockResolvedValue({ ...mockSale, status: 'PROCESSING' })

      const result = await saleService.respondToProposal('sale-1', 'ACCEPTED', 'user-1')

      expect(mockSaleRepo.update).toHaveBeenCalledWith('sale-1', expect.objectContaining({ status: 'PROCESSING' }))
      expect(mockSaleRepo.createAuditLog).toHaveBeenCalledWith(expect.objectContaining({ action: 'PROPOSAL_ACCEPTED' }))
    })

    it('should reject proposal and cancel sale', async () => {
      const mockSale = { 
        id: 'sale-1', 
        status: 'PROPOSED', 
        userId: 'user-1', 
        customerName: 'John',
        items: [{ productId: 'prod-1', quantity: 1, status: 'ACCEPTED' }]
      }
      mockSaleRepo.findById.mockResolvedValue(mockSale)
      mockProductRepo.findById.mockResolvedValue({ id: 'prod-1', stock: 10 })
      mockSaleRepo.update.mockResolvedValue({ ...mockSale, status: 'CANCELLED' })

      const result = await saleService.respondToProposal('sale-1', 'REJECTED', 'user-1')

      expect(mockSaleRepo.update).toHaveBeenCalledWith('sale-1', expect.objectContaining({ status: 'CANCELLED' }))
      expect(mockProductRepo.update).toHaveBeenCalledWith('prod-1', { stock: 11, inStock: true })
    })

    it('should throw error if user is not the owner', async () => {
      const mockSale = { id: 'sale-1', userId: 'user-1' }
      mockSaleRepo.findById.mockResolvedValue(mockSale)

      await expect(saleService.respondToProposal('sale-1', 'ACCEPTED', 'other-user'))
        .rejects.toThrow('No tienes permiso')
    })
  })

  describe('getSalesSummary', () => {
    it('should calculate summary correctly', async () => {
      const mockSales = [
        { status: 'COMPLETED', totalUSD: 100, totalBS: 3600, items: [{ quantity: 1 }] },
        { status: 'PENDING', totalUSD: 50, totalBS: 1800, items: [{ quantity: 2 }] }
      ]
      mockSaleRepo.getSummary.mockResolvedValue(mockSales)

      const summary = await saleService.getSalesSummary()

      expect(summary.totalSales).toBe(2)
      expect(summary.totals.totalUSD).toBe(100) // Only COMPLETED
      expect(summary.completedSalesCount).toBe(1)
      expect(summary.pendingSalesCount).toBe(1)
    })
  })
})
