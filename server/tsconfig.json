{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules", 
    "dist", 
    "src/**/__tests__/**", 
    "src/scripts/**", 
    "src/seed*.ts", 
    "src/test*.ts",
    "src/infrastructure/web/routes/admin/brand.routes.ts",
    "src/infrastructure/web/routes/admin/format.routes.ts",
    "src/infrastructure/web/routes/admin/inventory.routes.ts",
    "src/infrastructure/web/routes/admin/provider.routes.ts"
  ]
}
