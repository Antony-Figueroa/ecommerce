{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules", 
    "dist", 
    "src/**/__tests__/**", 
    "src/**/*.test.ts", 
    "src/**/*.spec.ts", 
    "src/test-*.ts", 
    "src/test-prisma.ts",
    "src/scripts/**",
    "src/seed-*.ts",
    "src/infrastructure/web/routes/ai-chat.routes.ts"
  ]
}
